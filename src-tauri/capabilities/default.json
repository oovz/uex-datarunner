{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop window capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-internal-toggle-maximize",
    "dialog:default",
    "log:default",
    "allow-cancel-ocr",
    "allow-check-uex-account",
    "allow-clear-working-set",
    "allow-delete-submitted-screenshots",
    "allow-get-ocr-status",
    "allow-hide-to-tray",
    "allow-list-screenshots",
    "allow-load-config",
    "allow-load-working-set",
    "allow-open-screenshot",
    "allow-prefetch-commodities",
    "allow-prefetch-data-parameters",
    "allow-prefetch-terminals",
    "allow-process-screenshots",
    "allow-process-selected-screenshots",
    "allow-save-config",
    "allow-save-working-set",
    "allow-search-commodities",
    "allow-submit-to-uex"
  ]
}
