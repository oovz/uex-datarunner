{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UEX Datarunner",
  "version": "0.1.1",
  "identifier": "app.oovz.uex-datarunner",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "UEX Datarunner",
        "width": 1180,
        "height": 820,
        "minWidth": 980,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
